{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug (CMake Preset)",
            "type": "shell",
            "command": "cube-cmake",
            "args": [
                "--build",
                "--preset",
                "Debug"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Flash STM32F446 (STLink)",
            "type": "shell",
            "command": "C:/ST/STM32CubeCLT_1.19.0/STM32CubeProgrammer/bin/STM32_Programmer_CLI.exe",
            "args": [
                "-c",
                "port=swd",
                "-d",
                "${workspaceFolder}/build/Debug/Device-emulator.elf",
                "-v",
                "-rst"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}